<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
  <h2 style="margin: 0;">Estates</h2>
  <button class="outline" data-dialog="create-estate-dialog">+ New Estate</button>
</div>

<% if (estates && estates.length > 0) { %>
  <ul style="list-style: none; padding: 0;">
    <% estates.forEach(function(estate) { %>
      <li style="margin-bottom: 0.5rem;">
        <a href="/admin/estates/<%= estate.id %>"><%= estate.name %></a>
      </li>
    <% }); %>
  </ul>
<% } else { %>
  <p style="color: var(--pico-muted-color);">No estates yet. Create one to get started.</p>
<% } %>

<!-- ── Create Estate Dialog ──────────────────────────────────────────────── -->
<dialog id="create-estate-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="create-estate-dialog"></button>
      <h3>Create New Estate</h3>
    </header>
    <form action="/admin/estates" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Estate Name
        <input type="text" name="name" placeholder="Enter estate name…" required autocomplete="off" />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="create-estate-dialog">Cancel</button>
        <button type="submit">Create</button>
      </footer>
    </form>
  </article>
</dialog>
