<a href="/admin" role="button" class="outline" style="margin-bottom: 2rem; display: inline-block;">← Dashboard</a>

<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.25rem;">
  <h2 style="margin: 0;"><%= estate.name %></h2>
  <button class="outline" data-dialog="rename-estate-dialog">Edit</button>
</div>
<p style="color: var(--pico-muted-color); margin-bottom: 2rem; font-size: 0.875rem;">Estate ID: <%= estate.id %></p>

<!-- Managers List -->
<section>
  <h3>Managers</h3>
  <% if (managers && managers.length > 0) { %>
    <ul style="list-style: none; padding: 0;">
      <% managers.forEach(function(manager) { %>
        <li style="margin-bottom: 0.5rem;">
          <a href="/users/<%= manager.id %>"><%= manager.firstName %> <%= manager.lastName %></a>
          <span style="color: var(--pico-muted-color); font-size: 0.875rem; margin-left: 0.5rem;"><%= manager.email %></span>
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    <p style="color: var(--pico-muted-color);">No managers yet.</p>
  <% } %>
  <button class="outline" style="margin-top: 1rem;" data-dialog="add-manager-dialog">+ Add Manager</button>
</section>

<!-- Danger Zone -->
<section style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--pico-muted-border-color);">
  <h4 style="color: var(--pico-del-color);">Danger Zone</h4>
  <p>Permanently delete this estate and all its data.</p>
  <button class="contrast outline" data-dialog="delete-estate-dialog">Delete Estate</button>
</section>

<!-- ── Rename Estate Dialog ───────────────────────────────────────────────── -->
<dialog id="rename-estate-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="rename-estate-dialog"></button>
      <h3>Rename Estate</h3>
    </header>
    <form action="/admin/estates/<%= estate.id %>/rename" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Estate Name
        <input type="text" name="name" value="<%= estate.name %>" required autocomplete="off" />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="rename-estate-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- ── Add Manager Dialog ─────────────────────────────────────────────────── -->
<dialog id="add-manager-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-manager-dialog"></button>
      <h3>Add Manager</h3>
    </header>
    <form action="/users/managers" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="estateId" value="<%= estate.id %>" />
      <label>
        First Name
        <input type="text" name="firstName" placeholder="First name" required autocomplete="off" />
      </label>
      <label>
        Last Name
        <input type="text" name="lastName" placeholder="Last name" required autocomplete="off" />
      </label>
      <label>
        Email
        <input type="email" name="email" placeholder="manager@example.com" required autocomplete="off" />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="add-manager-dialog">Cancel</button>
        <button type="submit">Add Manager</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- ── Delete Estate Dialog ───────────────────────────────────────────────── -->
<dialog id="delete-estate-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="delete-estate-dialog"></button>
      <h3>Delete Estate</h3>
    </header>
    <p>Are you sure you want to permanently delete <strong><%= estate.name %></strong> and all its data? This cannot be undone.</p>
    <form action="/admin/estates/<%= estate.id %>/delete" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <footer>
        <button type="button" class="outline" data-close-dialog="delete-estate-dialog">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
