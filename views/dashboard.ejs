<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hunt-Hub | Manager Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: {
        primary: { DEFAULT: "#1a4731", light: "#2d6a4f", dark: "#0f2d1e" },
        accent:  { DEFAULT: "#d97706", light: "#f59e0b", dark: "#b45309" },
      }}}
    }
  </script>
</head>
<body class="bg-stone-100 min-h-screen">

  <header class="bg-primary text-white px-8 py-4 flex items-center justify-between">
    <h1 class="text-lg font-semibold tracking-tight">
      Hunt-Hub <span class="font-light text-sm text-green-200 ml-1">Manager Dashboard</span>
    </h1>
    <form action="/logout" method="POST">
      <button type="submit"
        class="border border-white text-white text-sm px-4 py-1.5 rounded-lg hover:bg-white hover:text-primary transition">
        Log Out
      </button>
    </form>
  </header>

  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="bg-white rounded-xl shadow-sm p-8">
      <h2 class="text-2xl font-bold text-gray-800 mb-2">
        Welcome, <%= user.firstName %> <%= user.lastName %>
        <span class="inline-block bg-primary text-white text-xs px-3 py-0.5 rounded-full align-middle ml-2">Manager</span>
      </h2>
      <p class="text-gray-500 leading-relaxed">
        You are logged in as a manager. Use this dashboard to oversee your estate's operations and staff.
      </p>
    </div>
  </div>

</body>
</html>
