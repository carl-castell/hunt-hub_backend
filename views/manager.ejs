<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hunt-Hub | Manager Dashboard</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <h1>Hunt-Hub <span class="site-header-sub">Manager Dashboard</span></h1>
      <form action="/logout" method="POST">
        <button type="submit" class="btn btn-outline">Log Out</button>
      </form>
    </header>

    <div class="page-content">
      <div class="card">
        <h2>
          Welcome, <%= user.firstName %> <%= user.lastName %>
          <span class="badge">Manager</span>
        </h2>
        <p>You are logged in as a manager. Use this dashboard to oversee your estate's operations and staff.</p>
      </div>
    </div>
  </body>
</html>