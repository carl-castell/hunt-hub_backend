<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
  <h2 style="margin: 0;">People</h2>
  <button onclick="document.getElementById('create-user-dialog').showModal()">+ Add Team Member</button>
</div>

<!-- ── People Table ───────────────────────────────────────────────────────── -->
<% if (people.length === 0) { %>
  <p>No team members found.</p>
<% } else { %>
  <figure>
    <table>
      <thead>
        <tr>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Role</th>
        </tr>
      </thead>
      <tbody>
        <% people.forEach(person => { %>
          <tr
            style="cursor: pointer;"
            onclick="window.location='/manager/people/<%= person.id %>'"
          >
            <td><%= person.firstName %></td>
            <td><%= person.lastName %></td>
            <td style="text-transform: capitalize;"><%= person.role %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </figure>
<% } %>

<!-- ── Create User Dialog ─────────────────────────────────────────────────── -->
<dialog id="create-user-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('create-user-dialog').close()"></button>
      <h3>Add Team Member</h3>
    </header>
    <form action="/manager/people" method="POST">
      <label>
        First Name
        <input type="text" name="firstName" placeholder="First Name" required maxlength="255" />
      </label>
      <label>
        Last Name
        <input type="text" name="lastName" placeholder="Last Name" required maxlength="255" />
      </label>
      <label>
        Email
        <input type="email" name="email" placeholder="email@example.com" required maxlength="255" />
      </label>
      <label>
        Role
        <select name="role" required>
          <option value="staff">Staff</option>
          <option value="manager">Manager</option>
        </select>
      </label>
      <footer>
        <button type="button" class="outline" onclick="document.getElementById('create-user-dialog').close()">Cancel</button>
        <button type="submit">Create</button>
      </footer>
    </form>
  </article>
</dialog>
