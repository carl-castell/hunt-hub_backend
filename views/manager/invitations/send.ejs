<style>
  .send-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
  .send-header h2 { margin:0; }
  #send-container { position:relative; }
  .loading-overlay {
    display:none;
    position:absolute; inset:0;
    background:rgba(255,255,255,0.75);
    z-index:10;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:1rem;
    border-radius:8px;
  }
  .loading-overlay.active { display:flex; }
  .spinner {
    width:40px; height:40px;
    border:4px solid var(--pico-muted-border-color);
    border-top-color: var(--pico-primary);
    border-radius:50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="send-header">
  <h2>Send Invitations — <%= event.eventName %></h2>
</div>

<% if (invitations.length === 0) { %>
  <article>
    <p style="color:var(--pico-muted-color); margin:0;">No staged guests to send to. <a href="/manager/events/<%= event.id %>/invitations/new">Add guests</a> first.</p>
  </article>
<% } else { %>

<form id="send-form"
  hx-post="/manager/events/<%= event.id %>/invitations/send"
  hx-target="#send-container"
  hx-swap="innerHTML"
  hx-trigger="confirmed">

  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

  <div id="send-container" style="position:relative;">

    <div class="loading-overlay" id="loading-overlay">
      <div class="spinner"></div>
      <p style="margin:0; color:var(--pico-muted-color);">Sending emails…</p>
    </div>

    <article>
      <label>
        Message
        <textarea name="message" rows="8" required maxlength="5000"
          placeholder="Write your invitation message here…"></textarea>
        <small>Placeholders: <code>&#123;&#123;firstName&#125;&#125;</code> and <code>&#123;&#123;lastName&#125;&#125;</code> will be replaced with each guest's name.</small>
      </label>

      <label style="max-width:260px;">
        Respond By <small style="font-weight:normal;">(optional)</small>
        <input type="date" name="respondBy" min="<%= new Date().toISOString().split('T')[0] %>" />
      </label>
    </article>

    <article>
      <figure style="margin:0;">
        <table>
          <thead>
            <tr>
              <th>First Name</th>
              <th>Last Name</th>
              <th>Email</th>
              <th style="width:3rem; text-align:center;">
                <label style="margin:0; cursor:pointer;" title="Select all">
                  <input type="checkbox" id="select-all" checked style="margin:0;" />
                </label>
              </th>
            </tr>
          </thead>
          <tbody>
            <% invitations.forEach(inv => { %>
            <tr>
              <td><%= inv.firstName %></td>
              <td><%= inv.lastName %></td>
              <td><%= inv.email %></td>
              <td style="text-align:center;">
                <input type="checkbox" name="invitationIds" value="<%= inv.id %>" checked style="margin:0;" />
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </figure>
    </article>

    <div style="display:flex; justify-content:flex-end;">
      <button type="button" id="open-confirm-btn">Send Email</button>
    </div>

  </div>
</form>

<!-- Confirm dialog -->
<dialog id="confirm-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="confirm-dialog"></button>
      <h3>Confirm Send</h3>
    </header>
    <p style="margin-bottom:0.5rem;">Send invitation to the following guests?</p>
    <ul id="confirm-list" style="margin-top:0.5rem; padding-left:1.25rem;"></ul>
    <footer>
      <button type="button" class="outline" data-close-dialog="confirm-dialog">Cancel</button>
      <button type="button" id="do-send-btn">Confirm Send</button>
    </footer>
  </article>
</dialog>

<script>
  var selectAll = document.getElementById('select-all');
  selectAll.addEventListener('change', function () {
    document.querySelectorAll('input[name="invitationIds"]')
      .forEach(function (cb) { cb.checked = selectAll.checked; });
  });

  document.querySelectorAll('input[name="invitationIds"]').forEach(function (cb) {
    cb.addEventListener('change', function () {
      var all = document.querySelectorAll('input[name="invitationIds"]');
      var checked = document.querySelectorAll('input[name="invitationIds"]:checked');
      selectAll.checked = all.length === checked.length;
      selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
    });
  });

  document.getElementById('open-confirm-btn').addEventListener('click', function () {
    var checked = [...document.querySelectorAll('input[name="invitationIds"]:checked')];
    if (!checked.length) {
      alert('Please select at least one guest.');
      return;
    }
    var list = document.getElementById('confirm-list');
    list.innerHTML = checked.map(function (cb) {
      var row = cb.closest('tr');
      var cells = row.querySelectorAll('td');
      return '<li>' + cells[0].textContent.trim() + ' ' + cells[1].textContent.trim() +
             ' <span style="color:var(--pico-muted-color);">(' + cells[2].textContent.trim() + ')</span></li>';
    }).join('');
    document.getElementById('confirm-dialog').showModal();
  });

  document.getElementById('do-send-btn').addEventListener('click', function () {
    document.getElementById('confirm-dialog').close();
    document.getElementById('loading-overlay').classList.add('active');
    htmx.trigger(document.getElementById('send-form'), 'confirmed');
  });
</script>

<% } %>
