<% if (sent.length > 0) { %>
<article style="border-left:4px solid var(--pico-color-green-500); padding:1rem;">
  <strong><%= sent.length %> invitation<%= sent.length !== 1 ? 's' : '' %> sent successfully.</strong>
  <ul style="margin:0.5rem 0 0; padding-left:1.25rem;">
    <% sent.forEach(function(s) { %>
      <li><%= s.firstName %> <%= s.lastName %> — <span style="color:var(--pico-muted-color);"><%= s.email %></span></li>
    <% }) %>
  </ul>
</article>
<% } %>

<% if (failed.length > 0) { %>
<article style="border-left:4px solid var(--pico-color-red-500); padding:1rem; margin-top:1rem;">
  <strong><%= failed.length %> invitation<%= failed.length !== 1 ? 's' : '' %> failed to send.</strong>
  <figure style="margin:0.75rem 0 0;">
    <table>
      <thead>
        <tr><th>Name</th><th>Email</th><th>Error</th></tr>
      </thead>
      <tbody>
        <% failed.forEach(function(f) { %>
          <tr>
            <td><%= f.firstName %> <%= f.lastName %></td>
            <td><%= f.email %></td>
            <td style="color:var(--pico-color-red-500); font-size:0.85em;"><%= f.error %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </figure>
</article>
<% } %>

<% if (sent.length === 0 && failed.length === 0) { %>
<article>
  <p style="margin:0; color:var(--pico-muted-color);">No invitations were processed.</p>
</article>
<% } %>

<div style="margin-top:1.5rem;">
  <a href="/manager/events/<%= event.id %>/invitations" role="button" class="outline">Back to Guest List</a>
</div>
