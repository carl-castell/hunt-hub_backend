<style>
  .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .dash-header h3 { margin: 0; }

  .dash-event { display: flex; align-items: center; gap: 1rem; padding: 0.65rem 0;
                border-bottom: 1px solid var(--pico-muted-border-color);
                text-decoration: none; color: inherit; }
  .dash-event:last-child { border-bottom: none; }
  .dash-event:hover { opacity: 0.75; }
  .dash-event-date { font-size: 0.82rem; color: var(--pico-muted-color); min-width: 80px; }
  .dash-event-name { font-weight: 500; }

  .dash-area { display: block; padding: 0.55rem 0;
               border-bottom: 1px solid var(--pico-muted-border-color);
               text-decoration: none; }
  .dash-area:last-child { border-bottom: none; }

  .dash-nav { display: flex; align-items: center; justify-content: space-between;
              padding: 0.9rem 1rem; margin-bottom: 0.75rem;
              border: 1px solid var(--pico-muted-border-color);
              border-radius: var(--pico-border-radius);
              text-decoration: none; color: inherit; }
  .dash-nav:last-child { margin-bottom: 0; }
  .dash-nav:hover { background: var(--pico-card-sectionning-background-color); }
  .dash-nav span:last-child { color: var(--pico-muted-color); }
</style>

<!-- Upcoming Events (full width) -->
<article>
  <div class="dash-header">
    <h3>Upcoming Events</h3>
    <a href="/manager/events" class="secondary">View all →</a>
  </div>
  <% if (futureEvents.length === 0) { %>
    <p style="margin:0; color: var(--pico-muted-color);">
      No upcoming events. <a href="/manager/events">Create one →</a>
    </p>
  <% } else { %>
    <% futureEvents.forEach(event => { %>
      <a class="dash-event" href="/manager/events/<%= event.id %>">
        <span class="dash-event-date">
          <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
        </span>
        <span class="dash-event-name"><%= event.eventName %></span>
      </a>
    <% }) %>
  <% } %>
</article>

<!-- Areas + Quick Nav -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-top:1.5rem;">

  <article>
    <div class="dash-header"><h3>Areas</h3></div>
    <% if (areas.length === 0) { %>
      <p style="margin:0; color: var(--pico-muted-color);">
        No areas yet. <a href="/manager/estate">Add one →</a>
      </p>
    <% } else { %>
      <% areas.forEach(area => { %>
        <a class="dash-area" href="/manager/areas/<%= area.id %>"><%= area.name %></a>
      <% }) %>
    <% } %>
  </article>

  <article>
    <div class="dash-header"><h3>Go to</h3></div>
    <a class="dash-nav" href="/manager/guests">
      <span>Guests</span><span>→</span>
    </a>
    <a class="dash-nav" href="/manager/estate">
      <span>Estate</span><span>→</span>
    </a>
  </article>

</div>
