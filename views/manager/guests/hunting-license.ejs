<%
  function fmtDate(val) {
    if (!val) return '—';
    const d = new Date(val);
    if (isNaN(d)) return val;
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${dd}/${mm}/${yyyy}`;
  }
%>

<h2>Hunting License</h2>

<% if (!license) { %>
  <p style="margin: 0 0 0.25rem; font-weight: 600;"><%= guest.firstName %> <%= guest.lastName %></p>
  <p style="color: var(--pico-muted-color);">Date of Birth: <%= fmtDate(guest.dateOfBirth) %></p>
  <p style="color: #999;">No license selected.</p>
<% } else { %>
  <%
    const expiryUtc = new Date(`${license.expiryDate}T00:00:00Z`);
    const nowUtc = new Date(); nowUtc.setUTCHours(0,0,0,0);
    const diffMs = expiryUtc - nowUtc;
    const totalDays = Math.floor(Math.abs(diffMs) / 86400000);
    let expiryLabel, expiryColor;
    if (diffMs < 0) {
      expiryLabel = `expired since ${totalDays} day${totalDays !== 1 ? 's' : ''}`;
      expiryColor = '#dc2626';
    } else {
      const yrs = Math.floor(totalDays / 365);
      const mos = Math.floor((totalDays % 365) / 30);
      const dys = totalDays % 30;
      const parts = [];
      if (yrs) parts.push(`${yrs} year${yrs !== 1 ? 's' : ''}`);
      if (mos) parts.push(`${mos} month${mos !== 1 ? 's' : ''}`);
      if (dys || parts.length === 0) parts.push(`${dys} day${dys !== 1 ? 's' : ''}`);
      expiryLabel = `valid for ${parts.join(', ')}`;
      expiryColor = '#16a34a';
    }
  %>

  <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.5rem; gap: 1rem;">
    <div>
      <p style="margin: 0 0 0.25rem; font-weight: 600; font-size: 1.05rem;"><%= guest.firstName %> <%= guest.lastName %></p>
      <p style="margin: 0; color: var(--pico-muted-color);">Date of Birth: <%= fmtDate(guest.dateOfBirth) %></p>
    </div>
    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
      <% if (license.checked) { %>
        <span style="color: #0077cc; font-size: 0.9rem;">✔ Checked (<%= fmtDate(license.checkedAt) %>)</span>
      <% } %>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: flex-end;">
        <% if (!license.checked) { %>
          <form action="/manager/guests/<%= guest.id %>/hunting-license/check" method="POST" style="margin: 0;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="licenseId" value="<%= license.id %>" />
            <button type="submit" style="margin: 0; background: #16a34a; border-color: #16a34a;">date is valid</button>
          </form>
        <% } %>
        <button class="outline" data-dialog="edit-license-dialog" style="margin: 0;"><%= license.checked ? 'update license date' : 'edit date' %></button>
        <button class="secondary outline" data-dialog="delete-license-dialog" style="margin: 0;">delete license</button>
      </div>
    </div>
  </div>

  <article>
    <header>
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <p style="margin: 0;"><strong>Expiry Date:</strong> <%= fmtDate(license.expiryDate) %> <span style="color: <%= expiryColor %>; font-size: 0.9rem;">(<%= expiryLabel %>)</span></p>
        <small style="color: var(--pico-muted-color);">Uploaded: <%= fmtDate(license.uploadDate) %></small>
      </div>
    </header>

    <% license.attachments.forEach(attachment => { %>
      <% if (attachment.contentType.startsWith('image/')) { %>
        <img src="/manager/files/<%= attachment.key %>" style="max-width: 100%; margin-bottom: 1rem;" />
      <% } else { %>
        <div class="pdf-viewer" data-pdf-src="/manager/files/<%= attachment.key %>" style="margin-bottom: 1rem;"></div>
      <% } %>
    <% }) %>
    <script src="https://unpkg.com/pdfjs-dist@3.11.174/build/pdf.min.js"></script>
    <script>
      (function () {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://unpkg.com/pdfjs-dist@3.11.174/build/pdf.worker.min.js';
        async function renderPdf(container) {
          const pdf = await pdfjsLib.getDocument(container.dataset.pdfSrc).promise;
          const w = container.clientWidth || 800;
          for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const base = page.getViewport({ scale: 1 });
            const vp = page.getViewport({ scale: w / base.width });
            const canvas = document.createElement('canvas');
            canvas.width = vp.width;
            canvas.height = vp.height;
            canvas.style.cssText = 'width:100%;display:block;margin-bottom:0.5rem;';
            container.appendChild(canvas);
            await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
          }
        }
        document.querySelectorAll('.pdf-viewer').forEach(renderPdf);
      })();
    </script>
  </article>

  <dialog id="edit-license-dialog">
    <article>
      <header>
        <button aria-label="Close" rel="prev" data-close-dialog="edit-license-dialog"></button>
        <h3>Update License Date</h3>
      </header>
      <form action="/manager/guests/<%= guest.id %>/hunting-license/update" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="licenseId" value="<%= license.id %>" />
        <label>
          Expiry Date
          <input type="date" name="expiryDate" value="<%= license.expiryDate %>" required />
        </label>
        <footer>
          <button type="button" class="outline" data-close-dialog="edit-license-dialog">Cancel</button>
          <button type="submit">Save</button>
        </footer>
      </form>
    </article>
  </dialog>

  <dialog id="delete-license-dialog">
    <article>
      <header>
        <button aria-label="Close" rel="prev" data-close-dialog="delete-license-dialog"></button>
        <h3>Delete Hunting License</h3>
      </header>
      <p>Are you sure you want to permanently delete this hunting license? This cannot be undone.</p>
      <form action="/manager/guests/<%= guest.id %>/hunting-license/delete" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="licenseId" value="<%= license.id %>" />
        <footer>
          <button type="button" class="outline" data-close-dialog="delete-license-dialog">Cancel</button>
          <button type="submit" class="contrast">Delete</button>
        </footer>
      </form>
    </article>
  </dialog>
<% } %>
