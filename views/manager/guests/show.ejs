<%
  function fmtDate(val) {
    if (!val) return '—';
    const d = new Date(val);
    if (isNaN(d)) return val;
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${dd}/${mm}/${yyyy}`;
  }

  function timeUntilExpiry(dateStr) {
    const target = new Date(dateStr);
    const now = new Date();
    const diffMs = target - now;
    const totalDays = Math.floor(Math.abs(diffMs) / 86400000);

    if (totalDays > 365) return diffMs > 0 ? 'more than a year' : 'more than a year ago';

    if (diffMs <= 0) {
      return `${totalDays} day${totalDays !== 1 ? 's' : ''} ago`;
    }

    const years  = Math.floor(totalDays / 365);
    const months = Math.floor((totalDays % 365) / 30);
    const days   = totalDays % 30;
    const parts  = [];
    if (years)  parts.push(`${years} yr`);
    if (months) parts.push(`${months} mo`);
    if (days || parts.length === 0) parts.push(`${days} day${days !== 1 ? 's' : ''}`);
    return parts.join(', ');
  }

  function timeSinceIssue(dateStr) {
    const target = new Date(dateStr);
    const now = new Date();
    const totalDays = Math.floor((now - target) / 86400000);
    if (totalDays > 365) return 'more than a year';
    return `${totalDays} day${totalDays !== 1 ? 's' : ''} ago`;
  }
  const today = new Date().toISOString().split('T')[0];
%>

<style>
  .guest-header { display: flex; align-items: flex-start; justify-content: space-between; }
  .guest-meta { margin-top: 0.75rem; display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1rem; font-size: 0.9rem; }
  .guest-meta-label { color: var(--pico-muted-color); }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .section-header h3 { margin: 0; }
  .date-valid   { color: #16a34a; }
  .date-expired { color: #dc2626; }
</style>

<!-- Contact card -->
<article>
  <div class="guest-header">
    <div style="flex: 1;">
      <h2 style="margin: 0;"><%= guest.firstName %> <%= guest.lastName %></h2>
      <div class="guest-meta">
        <span class="guest-meta-label">Email</span>       <span><%= guest.email %></span>
        <span class="guest-meta-label">Phone</span>       <span><%= guest.phone || '—' %></span>
        <span class="guest-meta-label">Date of Birth</span><span><%= fmtDate(guest.dateOfBirth) %></span>
        <span class="guest-meta-label">Rating</span>      <span><%= guest.rating != null ? guest.rating + ' / 5' : '—' %></span>
      </div>
    </div>
    <details class="dropdown" style="margin: 0;">
      <summary role="button" class="outline" style="padding: 0.4rem 0.8rem;">⚙</summary>
      <ul dir="rtl">
        <li><a href="#" data-dialog="edit-guest-dialog">Edit</a></li>
        <li><a href="#" style="color: var(--pico-del-color);" data-dialog="delete-guest-dialog">Delete</a></li>
      </ul>
    </details>
  </div>
</article>

<!-- Guest Groups -->
<article style="margin-top: 1.5rem;">
  <div class="section-header">
    <h3>Groups</h3>
    <button class="outline" data-dialog="add-to-group-dialog">+ Add to Group</button>
  </div>
  <% if (guestGroups.length === 0) { %>
    <p style="color:var(--pico-muted-color); margin:0;">Not assigned to any group.</p>
  <% } else { %>
    <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
      <% guestGroups.forEach(g => { %>
        <span style="display:inline-flex; align-items:center; gap:0.4rem; background:var(--pico-code-background); border:1px solid var(--pico-muted-border-color); padding:0.25rem 0.6rem; border-radius:4px; font-size:0.9rem;">
          <a href="/manager/guest-groups/<%= g.id %>" style="text-decoration:none; color:inherit;"><%= g.name %></a>
          <form method="POST" action="/manager/guests/<%= guest.id %>/remove-from-group/<%= g.id %>" style="margin:0; line-height:1;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" style="background:none; border:none; padding:0; cursor:pointer; color:var(--pico-muted-color); font-size:0.8rem; line-height:1;" title="Remove from group">✕</button>
          </form>
        </span>
      <% }) %>
    </div>
  <% } %>
</article>

<!-- Add to Group dialog -->
<dialog id="add-to-group-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-to-group-dialog"></button>
      <h3>Add to Group</h3>
    </header>
    <form method="POST" action="/manager/guests/<%= guest.id %>/add-to-group">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <% if (availableGroups.length > 0) { %>
        <label>
          Existing group
          <select name="groupId" id="atg-select">
            <option value="">— select a group —</option>
            <% availableGroups.forEach(g => { %>
              <option value="<%= g.id %>"><%= g.name %></option>
            <% }) %>
          </select>
        </label>
        <p style="text-align:center; color:var(--pico-muted-color); margin:0.5rem 0;">or</p>
      <% } %>
      <label>
        Create new group
        <input type="text" name="newGroupName" id="atg-new" placeholder="New group name…" maxlength="255" />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="add-to-group-dialog">Cancel</button>
        <button type="submit">Add</button>
      </footer>
    </form>
  </article>
</dialog>
<script>
  (function () {
    const sel = document.getElementById('atg-select');
    const inp = document.getElementById('atg-new');
    if (!sel || !inp) return;
    sel.addEventListener('change', () => {
      if (sel.value) { inp.value = ''; inp.disabled = true; }
      else inp.disabled = false;
    });
    inp.addEventListener('input', () => {
      if (inp.value.trim()) { sel.value = ''; sel.disabled = true; }
      else sel.disabled = false;
    });
  })();
</script>

<!-- Licenses & Certificates -->
<article style="margin-top: 1.5rem;">
  <div class="section-header">
    <h3>Licenses & Certificates</h3>
    <div style="display: flex; gap: 0.5rem;">
      <button class="outline" data-dialog="add-license-dialog">+ Hunting License</button>
      <button class="outline" data-dialog="add-certificate-dialog">+ Certificate</button>
    </div>
  </div>

  <figure style="margin: 0;">
    <table>
      <tbody>
        <!-- Hunting Licenses -->
        <% if (licenses && licenses.length > 0) { %>
          <% licenses.forEach((license) => { %>
            <% const expired = new Date(license.expiryDate) < new Date(); %>
            <tr style="cursor: pointer;" data-href="/manager/guests/<%= guest.id %>/hunting-license?licenseId=<%= license.id %>">
              <td style="color:var(--pico-muted-color);">Hunting License</td>
              <td style="color:var(--pico-muted-color);">Expiry Date</td>
              <td><span class="<%= expired ? 'date-expired' : 'date-valid' %>"><%= fmtDate(license.expiryDate) %></span></td>
              <td style="color:var(--pico-muted-color);"><%= timeUntilExpiry(license.expiryDate) %></td>
              <td style="text-align: right;">
                <% if (license.checked) { %>
                  <span style="color: #0077cc;">✔ Checked (<%= fmtDate(license.checkedAt) %>)</span>
                <% } else { %>
                  <span style="color: var(--pico-muted-color);">✗ Unchecked</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td>Hunting License</td>
            <td colspan="4" style="color: var(--pico-muted-color);">No entry</td>
          </tr>
        <% } %>

        <!-- Training Certificates -->
        <% if (certificates && certificates.length > 0) { %>
          <% certificates.forEach((certificate) => { %>
            <tr style="cursor: pointer;" data-href="/manager/guests/<%= guest.id %>/training-certificate?certId=<%= certificate.id %>">
              <td style="color:var(--pico-muted-color);">Training Certificate</td>
              <td style="color:var(--pico-muted-color);">Issue Date</td>
              <td><%= fmtDate(certificate.issueDate) %></td>
              <td style="color:var(--pico-muted-color);"><%= timeSinceIssue(certificate.issueDate) %></td>
              <td style="text-align: right;">
                <% if (certificate.checked) { %>
                  <span style="color: #0077cc;">✔ Checked (<%= fmtDate(certificate.checkedAt) %>)</span>
                <% } else { %>
                  <span style="color: var(--pico-muted-color);">✗ Unchecked</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td>Training Certificate</td>
            <td colspan="4" style="color: var(--pico-muted-color);">No entry</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </figure>
</article>

<!-- Add Hunting License dialog -->
<dialog id="add-license-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-license-dialog"></button>
      <h3>Add Hunting License</h3>
    </header>
    <form id="license-upload-form" action="/manager/guests/<%= guest.id %>/hunting-license" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Expiry Date<input type="date" name="expiryDate" min="<%= today %>" required /></label>
      <label>
        Upload License File
        <input type="file" name="files" accept=".jpg,.jpeg,.png,.webp,.heic,.pdf" multiple required />
        <small>One PDF or up to 4 images</small>
      </label>
      <footer>
        <button type="button" class="outline" id="license-cancel-btn" data-close-dialog="add-license-dialog">Cancel</button>
        <button type="submit" id="license-upload-btn">Upload</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Add Training Certificate dialog -->
<dialog id="add-certificate-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-certificate-dialog"></button>
      <h3>Add Training Certificate</h3>
    </header>
    <form id="certificate-upload-form" action="/manager/guests/<%= guest.id %>/training-certificate" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Issue Date<input type="date" name="issueDate" max="<%= today %>" required /></label>
      <label>
        Upload Certificate File
        <input type="file" name="files" accept=".jpg,.jpeg,.png,.webp,.heic,.pdf" multiple required />
        <small>One PDF or up to 2 images</small>
      </label>
      <footer>
        <button type="button" class="outline" id="certificate-cancel-btn" data-close-dialog="add-certificate-dialog">Cancel</button>
        <button type="submit" id="certificate-upload-btn">Upload</button>
      </footer>
    </form>
  </article>
</dialog>

<script>
  (function () {
    var MAX_BYTES = 20 * 1024 * 1024;

    function checkFileSizes(input) {
      var files = Array.from(input.files);
      var tooBig = files.filter(function (f) { return f.size > MAX_BYTES; });
      if (tooBig.length) {
        alert('The following file(s) exceed the 20 MB limit and cannot be uploaded:\n' +
          tooBig.map(function (f) { return '• ' + f.name + ' (' + (f.size / 1024 / 1024).toFixed(1) + ' MB)'; }).join('\n'));
        input.value = '';
        return false;
      }
      return true;
    }

    function bindUploadLoading(formId, uploadBtnId, cancelBtnId) {
      var form = document.getElementById(formId);
      if (!form) return;
      var fileInput = form.querySelector('input[type="file"]');
      if (fileInput) {
        fileInput.addEventListener('change', function () { checkFileSizes(fileInput); });
      }
      form.addEventListener('submit', function (e) {
        if (fileInput && !checkFileSizes(fileInput)) { e.preventDefault(); return; }
        var btn = document.getElementById(uploadBtnId);
        var cancel = document.getElementById(cancelBtnId);
        if (btn) btn.setAttribute('aria-busy', 'true');
        if (cancel) cancel.disabled = true;
      });
    }
    bindUploadLoading('license-upload-form', 'license-upload-btn', 'license-cancel-btn');
    bindUploadLoading('certificate-upload-form', 'certificate-upload-btn', 'certificate-cancel-btn');
  })();
</script>

<!-- Edit Guest dialog -->
<dialog id="edit-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="edit-guest-dialog"></button>
      <h3>Edit Guest</h3>
    </header>
    <form action="/manager/guests/<%= guest.id %>/update" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>First Name<input type="text" name="firstName" value="<%= guest.firstName %>" required maxlength="255" /></label>
      <label>Last Name<input type="text" name="lastName" value="<%= guest.lastName %>" required maxlength="255" /></label>
      <label>Email<input type="email" name="email" value="<%= guest.email %>" required maxlength="255" /></label>
      <label>Phone<input type="text" name="phone" value="<%= guest.phone ?? '' %>" maxlength="255" /></label>
      <label>Date of Birth<input type="date" name="dateOfBirth" value="<%= guest.dateOfBirth ?? '' %>" /></label>
      <footer>
        <button type="button" class="outline" data-close-dialog="edit-guest-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Delete Guest dialog -->
<dialog id="delete-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="delete-guest-dialog"></button>
      <h3>Delete Guest</h3>
    </header>
    <p>Are you sure you want to permanently delete <strong><%= guest.firstName %> <%= guest.lastName %></strong>? This cannot be undone.</p>
    <form action="/manager/guests/<%= guest.id %>/delete" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <footer>
        <button type="button" class="outline" data-close-dialog="delete-guest-dialog">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
