<style>
  .user-header { display: flex; align-items: flex-start; justify-content: space-between; }
  .user-meta { margin-top: 0.5rem; font-size: 0.9rem; color: var(--pico-muted-color); display: flex; flex-direction: column; gap: 0.25rem; }
</style>

<% if (error) { %>
  <article style="border-left: 4px solid var(--pico-color-red-500); padding: 1rem; margin-bottom: 1.5rem;">
    <p style="margin: 0;"><%= error %></p>
  </article>
<% } %>

<article>
  <div class="user-header">
    <div>
      <h2 style="margin: 0;"><%= targetUser.firstName %> <%= targetUser.lastName %></h2>
      <div class="user-meta">
        <span><%= targetUser.email %></span>
        <span style="text-transform: capitalize;"><%= targetUser.role %> · <%= targetUser.active ? 'Active' : 'Inactive' %></span>
      </div>
    </div>
    <% if (targetUser.id !== user.id) { %>
      <details class="dropdown" style="margin: 0;">
        <summary role="button" class="outline" style="padding: 0.4rem 0.8rem;">⚙</summary>
        <ul dir="rtl">
          <li><a href="#" data-dialog="edit-role-dialog">Edit Role</a></li>
          <li><a href="#" style="color: var(--pico-del-color);" data-dialog="delete-user-dialog">Delete</a></li>
        </ul>
      </details>
    <% } %>
  </div>
</article>

<% if (targetUser.id !== user.id) { %>

<!-- Activation Link -->
<article style="margin-top: 1.5rem;">
  <header><strong>Activation Link</strong></header>
  <% if (activationToken) { %>
    <p>Share this link with the user to activate their account:</p>
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <input type="text" id="activation-link" value="<%= domain %>/activate/<%= activationToken %>" readonly style="flex: 1;" />
      <button type="button" class="outline" data-copy-target="activation-link">Copy</button>
    </div>
    <form action="/manager/people/<%= targetUser.id %>/resend-activation" method="POST" style="margin-top: 0.75rem;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="outline">Regenerate Link</button>
    </form>
  <% } else { %>
    <p>No pending activation token.</p>
    <form action="/manager/people/<%= targetUser.id %>/resend-activation" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="outline">Generate Activation Link</button>
    </form>
  <% } %>
</article>

<!-- Account Status -->
<article style="margin-top: 1.5rem;">
  <header><strong>Account Status</strong></header>
  <% if (targetUser.active) { %>
    <form action="/manager/people/<%= targetUser.id %>/deactivate" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="secondary outline">Deactivate Account</button>
    </form>
  <% } else { %>
    <form action="/manager/people/<%= targetUser.id %>/reactivate" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="outline">Reactivate Account</button>
    </form>
  <% } %>
</article>

<% } %>

<!-- Edit Role Dialog -->
<dialog id="edit-role-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="edit-role-dialog"></button>
      <h3>Edit Role</h3>
    </header>
    <form action="/manager/people/<%= targetUser.id %>/role" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Role
        <select name="role" required>
          <option value="staff" <%= targetUser.role === 'staff' ? 'selected' : '' %>>Staff</option>
          <option value="manager" <%= targetUser.role === 'manager' ? 'selected' : '' %>>Manager</option>
        </select>
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="edit-role-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Delete User Dialog -->
<dialog id="delete-user-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="delete-user-dialog"></button>
      <h3>Delete User</h3>
    </header>
    <p>Are you sure you want to permanently delete <strong><%= targetUser.firstName %> <%= targetUser.lastName %></strong>? This cannot be undone.</p>
    <form action="/manager/people/<%= targetUser.id %>/delete" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <footer>
        <button type="button" class="outline" data-close-dialog="delete-user-dialog">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
