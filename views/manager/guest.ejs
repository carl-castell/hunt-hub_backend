<%
  function fmtDate(val) {
    if (!val) return '—';
    const d = new Date(val);
    if (isNaN(d)) return val;
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${dd}/${mm}/${yyyy}`;
  }
%>

<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
  <h2 style="margin: 0;"><%= guest.firstName %> <%= guest.lastName %></h2>
  <button class="outline" data-dialog="edit-guest-dialog">Edit</button>
  <button class="secondary outline" data-dialog="delete-guest-dialog">Delete</button>
</div>

<a href="/manager/guests" role="button" class="outline" style="margin-bottom: 2rem; display: inline-block;">← Back to Guests</a>

<article>
  <dl>
    <dt>First Name</dt><dd><%= guest.firstName %></dd>
    <dt>Last Name</dt><dd><%= guest.lastName %></dd>
    <dt>Email</dt><dd><%= guest.email %></dd>
    <dt>Phone</dt><dd><%= guest.phone ?? '—' %></dd>
    <dt>Date of Birth</dt><dd><%= fmtDate(guest.dateOfBirth) %></dd>
  </dl>
</article>

<h3>Licenses & Certificates</h3>

<figure>
  <table>
    <tbody>
      <!-- Hunting Licenses (ALL) -->
      <% if (licenses && licenses.length > 0) { %>
        <% licenses.forEach((license) => { %>
          <%
            const licenseExpired = new Date(license.expiryDate) < new Date();
          %>
          <tr
            style="cursor: pointer;"
            data-href="/manager/guests/<%= guest.id %>/hunting-license?licenseId=<%= license.id %>"
          >
            <td>Hunting License</td>
            <td><strong>Expiry Date:</strong> <%= fmtDate(license.expiryDate) %></td>
            <td>
              <% if (license.checked) { %>
                <span style="color: #0077cc;">✔ Checked (<%= fmtDate(license.checkedAt) %>)</span>
              <% } else { %>
                <span style="color: #999;">✗ Unchecked</span>
              <% } %>
            </td>
            <td>
              <% if (licenseExpired) { %>
                <span style="color: red; font-weight: bold;">✗ Expired</span>
              <% } else { %>
                <span style="color: green; font-weight: bold;">✔ Valid</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td>Hunting License</td>
          <td colspan="3" style="color: #999;">No entry</td>
        </tr>
      <% } %>

      <!-- Training Certificates (ALL) -->
      <% if (certificates && certificates.length > 0) { %>
        <% certificates.forEach((certificate) => { %>
          <tr
            style="cursor: pointer;"
            data-href="/manager/guests/<%= guest.id %>/training-certificate?certId=<%= certificate.id %>"
          >
            <td>Training Certificate</td>
            <td><strong>Issue Date:</strong> <%= fmtDate(certificate.issueDate) %></td>
            <td>
              <% if (certificate.checked) { %>
                <span style="color: #0077cc;">✔ Checked (<%= fmtDate(certificate.checkedAt) %>)</span>
              <% } else { %>
                <span style="color: #999;">✗ Unchecked</span>
              <% } %>
            </td>
            <td></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td>Training Certificate</td>
          <td colspan="3" style="color: #999;">No entry</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</figure>

<div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
  <button class="outline" data-dialog="add-license-dialog">Add Hunting License</button>
  <button class="outline" data-dialog="add-certificate-dialog">Add Training Certificate</button>
</div>

<!-- Add Hunting License dialog -->
<dialog id="add-license-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-license-dialog"></button>
      <h3>Add Hunting License</h3>
    </header>
    <form action="/manager/guests/<%= guest.id %>/hunting-license" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Expiry Date<input type="date" name="expiryDate" required /></label>
      <label>
        Upload License File
        <input type="file" name="files" accept=".jpg,.jpeg,.png,.webp,.heic,.pdf" multiple required />
        <small>One PDF or up to 4 images</small>
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="add-license-dialog">Cancel</button>
        <button type="submit">Add</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Add Training Certificate dialog -->
<dialog id="add-certificate-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-certificate-dialog"></button>
      <h3>Add Training Certificate</h3>
    </header>
    <form action="/manager/guests/<%= guest.id %>/training-certificate" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Issue Date<input type="date" name="issueDate" required /></label>
      <label>
        Upload Certificate File
        <input type="file" name="files" accept=".jpg,.jpeg,.png,.webp,.heic,.pdf" multiple required />
        <small>One PDF or up to 2 images</small>
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="add-certificate-dialog">Cancel</button>
        <button type="submit">Add</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Edit Guest dialog -->
<dialog id="edit-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="edit-guest-dialog"></button>
      <h3>Edit Guest</h3>
    </header>
    <form action="/manager/guests/<%= guest.id %>/update" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>First Name<input type="text" name="firstName" value="<%= guest.firstName %>" required maxlength="255" /></label>
      <label>Last Name<input type="text" name="lastName" value="<%= guest.lastName %>" required maxlength="255" /></label>
      <label>Email<input type="email" name="email" value="<%= guest.email %>" required maxlength="255" /></label>
      <label>Phone<input type="text" name="phone" value="<%= guest.phone ?? '' %>" maxlength="255" /></label>
      <label>Date of Birth<input type="date" name="dateOfBirth" value="<%= guest.dateOfBirth ?? '' %>" /></label>
      <footer>
        <button type="button" class="outline" data-close-dialog="edit-guest-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Delete Guest dialog -->
<dialog id="delete-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="delete-guest-dialog"></button>
      <h3>Delete Guest</h3>
    </header>
    <p>Are you sure you want to permanently delete <strong><%= guest.firstName %> <%= guest.lastName %></strong>? This cannot be undone.</p>
    <form action="/manager/guests/<%= guest.id %>/delete" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <footer>
        <button type="button" class="outline" data-close-dialog="delete-guest-dialog">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
