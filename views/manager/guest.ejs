<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
  <h2 style="margin: 0;"><%= guest.firstName %> <%= guest.lastName %></h2>
  <button class="outline" data-dialog="edit-guest-dialog">Edit</button>
  <button class="secondary outline" data-dialog="delete-guest-dialog">Delete</button>
</div>

<a href="/manager/guests" role="button" class="outline" style="margin-bottom: 2rem; display: inline-block;">← Back to Guests</a>

<article>
  <dl>
    <dt>First Name</dt><dd><%= guest.firstName %></dd>
    <dt>Last Name</dt><dd><%= guest.lastName %></dd>
    <dt>Email</dt><dd><%= guest.email %></dd>
    <dt>Phone</dt><dd><%= guest.phone %></dd>
  </dl>
</article>

<dialog id="edit-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="edit-guest-dialog"></button>
      <h3>Edit Guest</h3>
    </header>
    <form action="/manager/guests/<%= guest.id %>/update" method="POST">
      <label>First Name<input type="text" name="firstName" value="<%= guest.firstName %>" required maxlength="255" /></label>
      <label>Last Name<input type="text" name="lastName" value="<%= guest.lastName %>" required maxlength="255" /></label>
      <label>Email<input type="email" name="email" value="<%= guest.email %>" required maxlength="255" /></label>
      <label>Phone<input type="text" name="phone" value="<%= guest.phone ?? '' %>" /></label>
      <label>Date of Birth<input type="date" name="dateOfBirth" value="<%= guest.dateOfBirth ?? '' %>" required /></label>

      <footer>
        <button type="button" class="outline" data-close-dialog="edit-guest-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<dialog id="delete-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="delete-guest-dialog"></button>
      <h3>Delete Guest</h3>
    </header>
    <p>Are you sure you want to permanently delete <strong><%= guest.firstName %> <%= guest.lastName %></strong>? This cannot be undone.</p>
    <form action="/manager/guests/<%= guest.id %>/delete" method="POST">
      <footer>
        <button type="button" class="outline" data-close-dialog="delete-guest-dialog">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
