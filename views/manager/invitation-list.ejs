<style>
  .inv-list-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .inv-list-header h2 { margin: 0; }
</style>

<div class="inv-list-header">
  <h2>Guest List — <%= event.eventName %></h2>
  <a href="/manager/events/<%= event.id %>/invitations/new" role="button">+ Select Guests</a>
</div>

<article>
  <% if (invitations.length === 0) { %>
    <p style="text-align:center; padding:2rem 0; color:var(--pico-muted-color); margin:0;">No guests invited yet.</p>
  <% } else { %>
    <figure style="margin:0;">
      <table>
        <thead>
          <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Status</th>
            <th>Response</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% invitations.forEach(inv => { %>
            <tr style="cursor:pointer;" data-href="/manager/events/<%= event.id %>/invitations/<%= inv.id %>">
              <td><%= inv.firstName %></td>
              <td><%= inv.lastName %></td>
              <td style="color:var(--pico-muted-color);"><%= inv.status %></td>
              <td style="color:var(--pico-muted-color);"><%= inv.response %></td>
              <td style="text-align:right; white-space:nowrap;">
                <details class="dropdown" style="margin:0; display:inline-block;">
                  <summary role="button" class="outline secondary" style="padding:0.25rem 0.6rem;">⋯</summary>
                  <ul dir="rtl">
                    <li><a href="#" style="color:var(--pico-del-color);" data-dialog="remove-inv-dialog-<%= inv.id %>">Remove from guest list</a></li>
                  </ul>
                </details>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </figure>
  <% } %>
</article>

<!-- Remove dialogs -->
<% invitations.forEach(inv => { %>
<dialog id="remove-inv-dialog-<%= inv.id %>">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="remove-inv-dialog-<%= inv.id %>"></button>
      <h3>Remove Guest</h3>
    </header>
    <p>Remove <strong><%= inv.firstName %> <%= inv.lastName %></strong> from the guest list?</p>
    <form method="POST" action="/manager/events/<%= event.id %>/invitations/<%= inv.id %>/remove">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <footer>
        <button type="button" class="outline" data-close-dialog="remove-inv-dialog-<%= inv.id %>">Cancel</button>
        <button type="submit" class="contrast">Remove</button>
      </footer>
    </form>
  </article>
</dialog>
<% }) %>
