<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
  <h2 style="margin: 0;">Guests</h2>
  <button data-dialog="add-guest-dialog">Add Guest</button>
</div>

<dialog id="add-guest-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="add-guest-dialog"></button>
      <h3>Add Guest</h3>
    </header>
    <form method="POST" action="/manager/guests">
      <label>First Name<input type="text" name="firstName" required /></label>
      <label>Last Name<input type="text" name="lastName" required /></label>
      <label>Email<input type="email" name="email" required /></label>
      <label>Phone<input type="text" name="phone" /></label>
      <label>Date of Birth<input type="date" name="dateOfBirth" /></label>
      <footer>
        <button type="button" class="outline" data-close-dialog="add-guest-dialog">Cancel</button>
        <button type="submit">Add Guest</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Filters -->
<form method="GET" action="/manager/guests" style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
  <input type="text" name="search" placeholder="Search guests..." value="<%= search %>" style="flex: 1; min-width: 200px;" />
  <select name="sortBy">
    <option value="" <%= sortBy === '' ? 'selected' : '' %>>Sort by...</option>
    <option value="firstName" <%= sortBy === 'firstName' ? 'selected' : '' %>>First Name</option>
    <option value="lastName" <%= sortBy === 'lastName' ? 'selected' : '' %>>Last Name</option>
  </select>
  <button type="submit">Apply</button>
  <a href="/manager/guests" role="button" class="outline">Clear</a>
</form>

<% if (guests.length === 0) { %>
  <p>No guests found.</p>
<% } else { %>
  <figure>
    <table>
      <thead>
        <tr><th>First Name</th><th>Last Name</th><th>Email</th><th>Phone</th></tr>
      </thead>
      <tbody>
        <% guests.forEach(guest => { %>
          <tr style="cursor: pointer;" data-href="/manager/guests/<%= guest.id %>">
            <td><%= guest.firstName %></td>
            <td><%= guest.lastName %></td>
            <td><%= guest.email %></td>
            <td><%= guest.phone %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </figure>
<% } %>
