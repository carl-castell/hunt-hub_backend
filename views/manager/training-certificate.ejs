<%
  function fmtDate(val) {
    if (!val) return '—';
    const d = new Date(val);
    if (isNaN(d)) return val;
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${dd}/${mm}/${yyyy}`;
  }
%>

<a href="/manager/guests/<%= guest.id %>" role="button" class="outline" style="margin-bottom: 2rem; display: inline-block;">← Back to Guest</a>

<h2><%= guest.firstName %> <%= guest.lastName %></h2>
<p><strong>Date of Birth:</strong> <%= fmtDate(guest.dateOfBirth) %></p>

<h3>Training Certificate</h3>

<% if (!certificate) { %>
  <p style="color: #999;">No certificate selected.</p>
<% } else { %>
  <article>
    <header>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <strong>Uploaded: <%= fmtDate(certificate.uploadDate) %></strong>
        <% if (certificate.checked) { %>
          <span style="color: #0077cc;">✔ Checked (<%= fmtDate(certificate.checkedAt) %>)</span>
        <% } else { %>
          <span style="color: #999;">✗ Unchecked</span>
        <% } %>
      </div>
    </header>

    <p><strong>Issue Date:</strong> <%= fmtDate(certificate.issueDate) %></p>

    <% certificate.attachments.forEach(attachment => { %>
      <% if (attachment.contentType.startsWith('image/')) { %>
        <img src="/manager/files/<%= attachment.key %>" style="max-width: 100%; margin-bottom: 1rem;" />
      <% } else { %>
        <p><a href="/manager/files/<%= attachment.key %>" target="_blank">View Document (<%= attachment.originalName %>)</a></p>
      <% } %>
    <% }) %>

    <footer style="display: flex; gap: 1rem;">
      <form action="/manager/guests/<%= guest.id %>/training-certificate/check" method="POST">
        <input type="hidden" name="certId" value="<%= certificate.id %>" />
        <button type="submit">✔ Certificate is Valid</button>
      </form>

      <button class="secondary outline" data-dialog="delete-certificate-dialog">Delete Certificate</button>
    </footer>
  </article>

  <dialog id="delete-certificate-dialog">
    <article>
      <header>
        <button aria-label="Close" rel="prev" data-close-dialog="delete-certificate-dialog"></button>
        <h3>Delete Training Certificate</h3>
      </header>
      <p>Are you sure you want to permanently delete this training certificate? This cannot be undone.</p>
      <form action="/manager/guests/<%= guest.id %>/training-certificate/delete" method="POST">
        <input type="hidden" name="certId" value="<%= certificate.id %>" />
        <footer>
          <button type="button" class="outline" data-close-dialog="delete-certificate-dialog">Cancel</button>
          <button type="submit" class="contrast">Delete</button>
        </footer>
      </form>
    </article>
  </dialog>
<% } %>
