<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
  <h2 style="margin: 0;"><%= event.eventName %></h2>
  <button class="outline" onclick="document.getElementById('edit-event-dialog').showModal()">Edit</button>
  <button class="secondary outline" onclick="document.getElementById('delete-event-dialog').showModal()">Delete</button>
</div>

<a href="/manager/events" role="button" class="outline" style="margin-bottom: 2rem; display: inline-block;">← Back to Events</a>

<!-- ── Event Info ─────────────────────────────────────────────────────────── -->
<article>
  <dl>
    <dt>Event Name</dt>
    <dd><%= event.eventName %></dd>

    <dt>Date</dt>
    <dd>
      <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
    </dd>

    <dt>Time</dt>
    <dd><%= event.time %></dd>
  </dl>
</article>

<!-- ── Edit Event Dialog ──────────────────────────────────────────────────── -->
<dialog id="edit-event-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('edit-event-dialog').close()"></button>
      <h3>Edit Event</h3>
    </header>
    <form action="/manager/events/<%= event.id %>/update" method="POST">
      <label>
        Event Name
        <input type="text" name="eventName" value="<%= event.eventName %>" required maxlength="255" />
      </label>
      <label>
        Date
        <input type="date" name="date" value="<%= event.date %>" required />
      </label>
      <label>
        Time
        <input type="time" name="time" value="<%= event.time %>" required />
      </label>
      <footer>
        <button type="button" class="outline" onclick="document.getElementById('edit-event-dialog').close()">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- ── Delete Event Dialog ────────────────────────────────────────────────── -->
<dialog id="delete-event-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('delete-event-dialog').close()"></button>
      <h3>Delete Event</h3>
    </header>
    <p>
      Are you sure you want to permanently delete
      <strong><%= event.eventName %></strong>?
      This cannot be undone.
    </p>
    <form action="/manager/events/<%= event.id %>/delete" method="POST">
      <footer>
        <button type="button" class="outline" onclick="document.getElementById('delete-event-dialog').close()">Cancel</button>
        <button type="submit" class="contrast">Delete</button>
      </footer>
    </form>
  </article>
</dialog>
