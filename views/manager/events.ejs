<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
  <h2 style="margin: 0;">Events</h2>
  <button data-dialog="create-event-dialog">+ New Event</button>
</div>

<!-- ── Upcoming Events ────────────────────────────────────────────────────── -->
<section style="margin-bottom: 2rem;">
  <h3>Upcoming Events</h3>
  <% if (upcomingEvents.length === 0) { %>
    <p>No upcoming events.</p>
  <% } else { %>
    <figure>
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Event Name</th>
          </tr>
        </thead>
        <tbody>
          <% upcomingEvents.forEach(event => { %>
            <tr style="cursor: pointer;" data-href="/manager/events/<%= event.id %>">
              <td>
                <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </td>
              <td><%= event.eventName %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </figure>
  <% } %>
</section>

<!-- ── Past Events ────────────────────────────────────────────────────────── -->
<section>
  <h3>Past Events</h3>
  <% if (pastEvents.length === 0) { %>
    <p>No past events.</p>
  <% } else { %>
    <figure>
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Event Name</th>
          </tr>
        </thead>
        <tbody>
          <% pastEvents.forEach(event => { %>
            <tr style="cursor: pointer;" data-href="/manager/events/<%= event.id %>">
              <td>
                <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </td>
              <td><%= event.eventName %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </figure>
  <% } %>
</section>

<!-- ── Create Event Dialog ────────────────────────────────────────────────── -->
<dialog id="create-event-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="create-event-dialog"></button>
      <h3>New Event</h3>
    </header>
    <form action="/manager/events" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Event Name
        <input type="text" name="eventName" placeholder="e.g. Autumn Hunt" required maxlength="255" />
      </label>
      <label>
        Date
        <input type="date" name="date" required />
      </label>
      <label>
        Time
        <input type="time" name="time" required />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="create-event-dialog">Cancel</button>
        <button type="submit">Create</button>
      </footer>
    </form>
  </article>
</dialog>
