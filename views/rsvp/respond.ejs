<div class="rsvp-card">
  <div class="rsvp-header">
    <h1><%= invitation.eventName %></h1>
    <p>
      <%= new Date(invitation.eventDate).toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      <% if (invitation.eventTime) { %>&nbsp;&middot;&nbsp;<%= invitation.eventTime.slice(0,5) %><% } %>
    </p>
  </div>

  <% if (drives.length > 0) { %>
  <article style="margin-bottom:1.5rem;">
    <header style="padding-bottom:0.5rem;"><strong>Drives</strong></header>
    <figure style="margin:0;">
      <table>
        <thead>
          <tr><th>Drive</th><th>Start</th><th>End</th></tr>
        </thead>
        <tbody>
          <% drives.forEach(function(d) { %>
          <tr>
            <td><%= d.name %></td>
            <td><%= d.startTime.slice(0,5) %></td>
            <td><%= d.endTime.slice(0,5) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </figure>
  </article>
  <% } %>

  <% if (invitation.respondBy) { %>
  <article style="border-left:4px solid var(--pico-primary); margin-bottom:1.5rem;">
    <p style="margin:0;">
      Please respond by
      <strong><%= new Date(invitation.respondBy).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>.
    </p>
  </article>
  <% } %>

  <p style="text-align:center; margin-bottom:1.5rem;">
    Hello <strong><%= invitation.firstName %></strong>, do you accept this invitation?
  </p>

  <div style="display:flex; gap:1rem; justify-content:center;">
    <button type="button" id="btn-yes">Yes, I accept</button>
    <button type="button" class="outline secondary" id="btn-no">No, I decline</button>
  </div>
</div>

<!-- Yes confirmation dialog -->
<dialog id="dialog-yes">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('dialog-yes').close()"></button>
      <h3>Accept Invitation</h3>
    </header>
    <p>Are you sure you want to accept the invitation to <strong><%= invitation.eventName %></strong>?</p>
    <footer>
      <button type="button" class="outline" onclick="document.getElementById('dialog-yes').close()">Cancel</button>
      <form method="POST" action="/rsvp/<%= invitation.publicId %>/respond" style="display:inline;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="answer" value="yes" />
        <button type="submit">Yes, accept</button>
      </form>
    </footer>
  </article>
</dialog>

<!-- No confirmation dialog -->
<dialog id="dialog-no">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('dialog-no').close()"></button>
      <h3>Decline Invitation</h3>
    </header>
    <p>Are you sure you want to decline the invitation to <strong><%= invitation.eventName %></strong>?</p>
    <footer>
      <button type="button" class="outline" onclick="document.getElementById('dialog-no').close()">Cancel</button>
      <form method="POST" action="/rsvp/<%= invitation.publicId %>/respond" style="display:inline;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="answer" value="no" />
        <button type="submit" class="secondary">Decline</button>
      </form>
    </footer>
  </article>
</dialog>

<script>
  document.getElementById('btn-yes').addEventListener('click', function () {
    document.getElementById('dialog-yes').showModal();
  });
  document.getElementById('btn-no').addEventListener('click', function () {
    document.getElementById('dialog-no').showModal();
  });
</script>
