<div class="rsvp-card">
  <div class="rsvp-header">
    <h1>Thank You!</h1>
    <p>Your response for <strong><%= invitation.eventName %></strong> has been recorded.</p>
  </div>

  <article>
    <header><strong>Documents</strong></header>

    <div class="status-row">
      <span class="status-icon"><%= (hasLicense || hasValidCheckedLicense) ? '✅' : '⬜' %></span>
      <% if (hasValidCheckedLicense) { %>
      <span>Hunting License <small style="color:var(--pico-muted-color);">(valid license on file)</small></span>
      <% } else { %>
      <span>Hunting License</span>
      <% if (!hasLicense) { %>
      <a href="/rsvp/<%= invitation.publicId %>?step=1" style="margin-left:auto; font-size:0.85rem;">Upload</a>
      <% } %>
      <% } %>
    </div>

    <div class="status-row">
      <span class="status-icon"><%= hasCert ? '✅' : '⬜' %></span>
      <span>Training Certificate</span>
      <% if (!hasCert) { %>
      <a href="/rsvp/<%= invitation.publicId %>?step=2" style="margin-left:auto; font-size:0.85rem;">Upload</a>
      <% } %>
    </div>
  </article>

  <article>
    <header><strong>Personal Details</strong></header>

    <div class="status-row">
      <span class="status-icon"><%= contact?.dateOfBirth ? '✅' : '⬜' %></span>
      <span>Date of Birth<% if (contact?.dateOfBirth) { %>: <strong><%= String(contact.dateOfBirth).slice(0,10) %></strong><% } %></span>
    </div>

    <div class="status-row">
      <span class="status-icon"><%= contact?.phone ? '✅' : '⬜' %></span>
      <span>Phone<% if (contact?.phone) { %>: <strong><%= contact.phone %></strong><% } %></span>
    </div>

    <div style="margin-top:1rem;">
      <a href="/rsvp/<%= invitation.publicId %>?step=3" role="button" class="outline" style="font-size:0.9rem;">
        Update Personal Details
      </a>
    </div>
  </article>

  <div style="margin-top:1.5rem; text-align:center;">
    <button type="button" class="outline secondary" id="btn-decline" style="font-size:0.9rem;">
      Change my answer to No
    </button>
  </div>
</div>

<!-- Decline confirmation dialog -->
<dialog id="dialog-decline">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('dialog-decline').close()"></button>
      <h3>Decline Invitation</h3>
    </header>
    <p>Are you sure you want to change your response to <strong>No</strong> for <em><%= invitation.eventName %></em>?</p>
    <footer>
      <button type="button" class="outline" onclick="document.getElementById('dialog-decline').close()">Cancel</button>
      <form method="POST" action="/rsvp/<%= invitation.publicId %>/respond" style="display:inline;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="answer" value="no" />
        <button type="submit" class="secondary">Yes, decline</button>
      </form>
    </footer>
  </article>
</dialog>

<script>
  document.getElementById('btn-decline').addEventListener('click', function () {
    document.getElementById('dialog-decline').showModal();
  });
</script>
