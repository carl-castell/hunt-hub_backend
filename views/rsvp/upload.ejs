<div class="rsvp-card">
  <div class="rsvp-header">
    <h1>You've Accepted!</h1>
    <p><%= invitation.eventName %></p>
  </div>

  <!-- Step indicator -->
  <nav style="display:flex; gap:0.5rem; justify-content:center; margin-bottom:2rem;">
    <% ['Hunting License','Training Certificate','Personal Details'].forEach(function(label, i) { %>
    <span style="padding:0.3rem 0.8rem; border-radius:999px; font-size:0.8rem;
                 background:<%= step === i+1 ? 'var(--pico-primary)' : '#e0e0e0' %>;
                 color:<%= step === i+1 ? '#fff' : '#666' %>;">
      <%= i+1 %>. <%= label %>
    </span>
    <% }) %>
  </nav>

  <p style="color:var(--pico-muted-color); font-size:0.9rem; text-align:center; margin-bottom:1.5rem;">
    You can return to this page at any time using the link in your email.
  </p>

  <!-- ── Step 1: Hunting License ─────────────────────────────────────── -->
  <% if (step === 1) { %>
  <% if (hasValidCheckedLicense) { %>
  <article style="border-left:4px solid var(--pico-color-green-500);">
    <header><strong>Hunting License</strong></header>
    <p style="margin:0;">We already have a valid hunting license on file for you — no upload needed.</p>
  </article>
  <div style="display:flex; justify-content:flex-end; margin-top:1rem;">
    <a href="/rsvp/<%= invitation.publicId %>?step=2" role="button">Next</a>
  </div>
  <% } else { %>
  <form method="POST" action="/rsvp/<%= invitation.publicId %>/upload/license" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <article>
      <header><strong>Hunting License</strong></header>

      <label>
        License File(s) <small style="font-weight:normal;">(PDF or up to 4 images)</small>
        <input type="file" name="licenseFiles" multiple accept=".pdf,image/jpeg,image/png,image/webp,image/heic" />
      </label>

      <label style="max-width:260px;">
        Expiry Date
        <input type="date" name="expiryDate" required />
      </label>
    </article>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1rem;">
      <a href="/rsvp/<%= invitation.publicId %>?step=2" style="color:var(--pico-muted-color); font-size:0.9rem;">
        Skip for now &rarr;
      </a>
      <button type="submit">Next</button>
    </div>
  </form>
  <% } %>
  <% } %>

  <!-- ── Step 2: Training Certificate ──────────────────────────────────── -->
  <% if (step === 2) { %>
  <form method="POST" action="/rsvp/<%= invitation.publicId %>/upload/certificate" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <article>
      <header><strong>Training Certificate</strong></header>

      <label>
        Certificate File(s) <small style="font-weight:normal;">(PDF or up to 2 images)</small>
        <input type="file" name="certFiles" multiple accept=".pdf,image/jpeg,image/png,image/webp,image/heic" />
      </label>

      <label style="max-width:260px;">
        Issue Date
        <input type="date" name="issueDate" required />
      </label>
    </article>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1rem;">
      <a href="/rsvp/<%= invitation.publicId %>?step=3" style="color:var(--pico-muted-color); font-size:0.9rem;">
        Skip for now &rarr;
      </a>
      <button type="submit">Next</button>
    </div>
  </form>
  <% } %>

  <!-- ── Step 3: Personal Details ───────────────────────────────────────── -->
  <% if (step === 3) { %>
  <form method="POST" action="/rsvp/<%= invitation.publicId %>/upload/details">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <article>
      <header><strong>Personal Details</strong></header>

      <label style="max-width:260px;">
        Date of Birth
        <input type="date" name="dateOfBirth"
               value="<%= contact?.dateOfBirth ? String(contact.dateOfBirth).slice(0,10) : '' %>" />
      </label>

      <label style="max-width:260px;">
        Phone Number
        <input type="tel" name="phone" placeholder="+353 87 000 0000"
               value="<%= contact?.phone ?? '' %>" />
      </label>
    </article>

    <div style="display:flex; justify-content:flex-end; margin-top:1rem;">
      <button type="submit">Finish</button>
    </div>
  </form>
  <% } %>
</div>
