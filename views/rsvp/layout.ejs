<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css" />
  <style>
    body { background: #f8f8f8; }
    main { padding-top: 3rem; padding-bottom: 3rem; }
    .rsvp-card { background: #fff; border-radius: 10px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); padding: 2rem; }
    .rsvp-header { text-align: center; margin-bottom: 2rem; }
    .rsvp-header h1 { margin-bottom: 0.25rem; font-size: 1.6rem; }
    .rsvp-header p { color: var(--pico-muted-color); margin: 0; }
    .status-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
    .status-icon { font-size: 1.1rem; }
  </style>
</head>
<body>
  <main class="container" style="max-width: 680px;">
    <%- body %>
  </main>
</body>
</html>
