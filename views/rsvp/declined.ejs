<div class="rsvp-card" style="text-align:center;">
  <div class="rsvp-header">
    <h1>Invitation Declined</h1>
    <p><%= invitation.eventName %></p>
  </div>

  <p style="color:var(--pico-muted-color);">
    You have declined this invitation.<br />
    <% if (invitation.eventDate) { %>
    The event is on
    <strong><%= new Date(invitation.eventDate).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></strong>.
    <% } %>
  </p>

  <p style="margin-top:1.5rem; font-size:0.9rem; color:var(--pico-muted-color);">
    If you think this was a mistake, please contact the organiser directly.
  </p>
</div>
