<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .container {
        text-align: center;
        background: #fff;
        padding: 60px 80px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }

      h1 {
        font-size: 3rem;
        color: #222;
        margin-bottom: 16px;
      }

      p {
        font-size: 1.1rem;
        color: #666;
        max-width: 400px;
        margin: 0 auto 32px auto;
        line-height: 1.6;
      }

      .btn-login {
        display: inline-block;
        padding: 12px 36px;
        background-color: #222;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
        font-size: 1rem;
        transition: background-color 0.2s ease;
      }

      .btn-login:hover {
        background-color: #444;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1><%= title %></h1>
      <p>
        Welcome to Hunt-Hub — your go-to platform for discovering and tracking
        the best opportunities. Join us and start your hunt today.
      </p>
      <a href="/login" class="btn-login">Log In</a>
    </div>
  </body>
</html>
