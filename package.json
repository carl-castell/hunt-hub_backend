{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "dev": "nodemon --exec tsx src/index.ts",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "studio": "DRIZZLE_DRIVER=pg drizzle-kit studio",
    "db:gen": "drizzle-kit generate",
    "db:push": "DRIZZLE_DRIVER=pg drizzle-kit push",
    "db:push:neon": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:clear": "tsx src/db/clear.ts",
    "db:reset": "docker compose down -v && docker compose up -d && node -e \"console.log('Waiting for DB...')\" && tsx -e \"setTimeout(()=>process.exit(0), 2000)\" && npm run db:push && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@faker-js/faker": "^9.2.0",
    "@neondatabase/serverless": "^0.10.1",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.5",
    "nodemailer-mailgun-transport": "^2.1.5",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.7.2",
    "@types/nodemailer": "^6.4.16",
    "@types/nodemailer-mailgun-transport": "^1.4.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.4"
  }
}
